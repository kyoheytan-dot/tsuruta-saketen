<!-- 管理パネル -->
<div class="admin-overlay" id="admin-overlay">
  <div class="admin-head">
    <div class="admin-title">商品管理画面</div>
    <button class="admin-close" onclick="closeAdmin()">閉じる</button>
  </div>
  <div class="admin-body">
    <div class="admin-notice">
      <strong>パスワード変更</strong>
      <div class="admin-url-row">
        <input type="password" class="admin-url-in" id="pw-new" placeholder="新しいパスワード">
        <button class="admin-url-save" onclick="changePw()">変更</button>
      </div>
    </div>
    <button class="admin-add-btn" onclick="openEdit(null)">+ 商品を追加する</button>
    <div id="admin-list"></div>
    <button class="admin-reset" onclick="resetProds()">商品リストを初期値にリセット</button>
  </div>
</div>

<!-- 商品編集モーダル -->
<div class="edit-overlay" id="edit-overlay">
  <div class="edit-modal">
    <div class="edit-title" id="edit-title">商品を追加</div>
    <div class="ef"><label>カテゴリ</label>
      <input type="text" id="eg" placeholder="例：国分酒造" list="eg-dl"><datalist id="eg-dl"></datalist>
    </div>
    <div class="ef"><label>商品名</label><input type="text" id="en" placeholder="例：伊佐美"></div>
    <div class="ef"><label>蔵元・補足</label><input type="text" id="ek" placeholder="例：国分酒造"></div>
    <div class="ef"><label>説明文</label><textarea id="edesc" placeholder="味わいの説明など"></textarea></div>
    <div class="ef"><label>商品画像URL（任意）</label><input type="text" id="eimg" placeholder="https://..."></div>
    <div class="ef-row">
      <div class="ef"><label>容量1</label><input type="text" id="es1" placeholder="1800ml"></div>
      <div class="ef"><label>価格1（円）</label><input type="number" id="ep1" placeholder="2500" inputmode="numeric"></div>
    </div>
    <div class="ef-row">
      <div class="ef"><label>容量2（任意）</label><input type="text" id="es2" placeholder="720ml"></div>
      <div class="ef"><label>価格2（円）</label><input type="number" id="ep2" placeholder="" inputmode="numeric"></div>
    </div>
    <div class="ef-row">
      <div class="ef"><label>容量3（任意）</label><input type="text" id="es3" placeholder="900ml"></div>
      <div class="ef"><label>価格3（円）</label><input type="number" id="ep3" placeholder="" inputmode="numeric"></div>
    </div>
    <div class="ef"><label>バッジ（カンマ区切り）</label><input type="text" id="ebadge" placeholder="鹿児島限定,数量限定"></div>
    <div class="check-row"><input type="checkbox" id="ei" checked><label for="ei">在庫あり（外すと「完売」表示）</label></div>
    <div class="edit-btns">
      <button class="e-cancel" onclick="closeEdit()">キャンセル</button>
      <button class="e-save" onclick="saveProd()">保存する</button>
    </div>
  </div>
</div>

