    <div class="pw-sub">パスワードを入力してください</div>
    <input type="password" class="pw-input" id="pw-input" placeholder="****" maxlength="20" onkeydown="if(event.key==='Enter')checkPw()">
    <div class="pw-err" id="pw-err"></div>
    <button class="pw-submit" onclick="checkPw()">ログイン</button>
    <br><button class="pw-cancel" onclick="closePw()">キャンセル</button>
  </div>
